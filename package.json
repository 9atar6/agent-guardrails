{
  "name": "agent-guardrails",
  "version": "1.2.4",
  "private": true,
  "description": "Agent Guardrails — a simple, open format for AI agent constraints",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/9atar6/agent-guardrails.git"
  },
  "scripts": {
    "validate": "node guardrails-ref/dist/cli.js validate .",
    "list": "node guardrails-ref/dist/cli.js list .",
    "setup": "node guardrails-ref/dist/cli.js setup .",
    "init": "node guardrails-ref/dist/cli.js init .",
    "add": "node guardrails-ref/dist/cli.js add",
    "remove": "node guardrails-ref/dist/cli.js remove",
    "upgrade": "node guardrails-ref/dist/cli.js upgrade .",
    "diff": "node guardrails-ref/dist/cli.js diff .",
    "why": "node guardrails-ref/dist/cli.js why",
    "build": "npm run build --prefix guardrails-ref",
    "test": "npm test --prefix guardrails-ref"
  }
}
